# ─── postmortem ☠ ────────────────────────────────────────────────────────────

# Dependencies
node_modules/
.pnp/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build output
dist/
build/
out/
*.tsbuildinfo
.tsup/

# Test / coverage
coverage/
.nyc_output/
*.lcov
.vitest/

# Native addon build artifacts (better-sqlite3)
build/Release/
prebuilds/
*.node

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data (postmortem writes here on a user's machine — never commit)
.postmortem/
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
.npmrc

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~
.history/

# OS cruft
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Caches
.cache/
.npm/
.eslintcache
.biome-cache/

# Temp
tmp/
temp/
*.tmp
